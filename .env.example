# PostgreSQL connection string (use Vercel Postgres / Neon / Supabase in production)
DATABASE_URL=postgresql://user:password@host:5432/dbname

# Long random string — generate with: openssl rand -base64 32
PAYLOAD_SECRET=change-me-to-a-long-random-string

# Your production URL (used by Payload for CORS and absolute URLs)
NEXT_PUBLIC_SERVER_URL=https://integraflow-site.vercel.app/
